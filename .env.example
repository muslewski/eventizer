# ── Core ────────────────────────────────────────────────────────────────────
# Postgres connection string (Vercel Postgres in prod; docker-compose locally:
# postgres://postgres:postgres@localhost:5432/eventizer)
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/eventizer
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Auth (Better Auth — required at boot) ────────────────────────────────────
# Session signing secret (read implicitly by better-auth).
BETTER_AUTH_SECRET=
# Canonical app URL for Better Auth (read implicitly), e.g. http://localhost:3000 in dev.
BETTER_AUTH_URL=http://localhost:3000
# Base URL the Better Auth client uses in the browser (src/auth/auth-client.ts).
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_PROVIDER_CLIENT_ID=
GOOGLE_PROVIDER_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

# ── Stripe (provider subscriptions) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOKS_ENDPOINT_SECRET=

# ── Uploads (Vercel Blob) ────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Maps ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── AI offer-content generation (used by @ai-sdk/openai) ─────────────────────
OPENAI_API_KEY=

# ── Live preview ─────────────────────────────────────────────────────────────
# Payload server URL used by the offer live-preview components.
NEXT_PUBLIC_PAYLOAD_SERVER_URL=http://localhost:3000

# ── Ops ──────────────────────────────────────────────────────────────────────
# Required — the purge cron rejects all requests when unset.
CRON_SECRET=
# Secret for Payload draft live-preview links.
PREVIEW_SECRET=

# Set to "true" to show the free beta option on the onboarding plan-selection step.
# Remove or set to "false" when the beta period ends.
BETA_MODE=false
